{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "includeFiles": [
        "macronizer.py",
        "lemmas.py",
        "postags.py",
        "macronized_endings.py",
        "macronizer.db",
        "macrons.txt",
        "morpheus/**",
        "rftagger-ldt.model",
        "bin/rftagger/**",
        "requirements.txt"
      ]
    }
  }
}
